## Required base API URL
VISTA_API_BASE_URL=https://api.example.com

## Optional default enterprise for enterprise-scoped tools
VISTA_ENTERPRISE_ID=

## Configure one auth mode for API endpoints
VISTA_AUTH_MODE=static
VISTA_AUTH_STRATEGY=delegated_passthrough
VISTA_BEARER_TOKEN=
VISTA_API_KEY=
VISTA_API_KEY_HEADER=x-api-key

## Server-managed TID OAuth settings (required for server-managed mode)
VISTA_CLIENT_ID=
VISTA_CLIENT_SECRET=
VISTA_SCOPE=openid vista_agent
VISTA_ACCESS_TOKEN=
VISTA_REFRESH_TOKEN=
## Optional override. If blank, token URL is built from VISTA_AUTH_ISSUER + /oauth/token
VISTA_TOKEN_URL=
## Optional for delegated token_exchange strategy
VISTA_TOKEN_EXCHANGE_TOKEN_URL=
VISTA_TOKEN_EXCHANGE_SCOPE=
VISTA_TOKEN_EXCHANGE_SUBJECT_TOKEN_TYPE=urn:ietf:params:oauth:token-type:jwt
VISTA_TOKEN_EXCHANGE_REQUESTED_TOKEN_TYPE=urn:ietf:params:oauth:token-type:jwt
VISTA_TOKEN_EXCHANGE_AUDIENCE=

## Delegated bearer auth settings (required for delegated/hybrid modes)
VISTA_AUTH_ISSUER=
VISTA_AUTH_JWKS_URL=
VISTA_AUTH_AUDIENCE=
VISTA_AUTH_REQUIRED_SCOPES=
VISTA_AUTH_JWKS_CACHE_TTL_SECONDS=300
VISTA_AUTH_JWT_LEEWAY_SECONDS=60
VISTA_AUTH_RESOURCE_SERVER_URL=

## Optional request metadata and timeout
VISTA_CORRELATION_ID=
VISTA_REQUEST_TIMEOUT_SECONDS=45
VISTA_REQUEST_CONNECT_TIMEOUT_SECONDS=10
VISTA_REQUEST_READ_TIMEOUT_SECONDS=45
VISTA_REQUEST_WRITE_TIMEOUT_SECONDS=30
VISTA_REQUEST_POOL_TIMEOUT_SECONDS=10
VISTA_REQUEST_MAX_CONNECTIONS=100
VISTA_REQUEST_MAX_KEEPALIVE_CONNECTIONS=40
VISTA_MAX_CONCURRENT_REQUESTS=32
VISTA_MAX_CONCURRENT_ANALYSIS_RUNS=4

## Optional if health endpoints are hosted separately
VISTA_HEALTH_BASE_URL=

## Optional tool toggles
VISTA_INCLUDE_TEST_ENTERPRISE_TOOL=true
VISTA_INCLUDE_HEALTH_ALIVE_TOOL=true

## Optional read-only invoice analysis knobs
VISTA_ANALYSIS_DEFAULT_WINDOW_DAYS=365
VISTA_ANALYSIS_DEFAULT_TOP_N=5
VISTA_ANALYSIS_PAGE_SIZE=100
VISTA_ANALYSIS_MAX_PAGES=10
VISTA_ANALYSIS_STALE_DAYS=30
VISTA_ANALYSIS_HIGH_AMOUNT_THRESHOLD=50000
VISTA_ANALYSIS_DUPLICATE_AMOUNT_DELTA=0.01
VISTA_ANALYSIS_POLICY_PROFILE=standard
VISTA_ANALYSIS_CACHE_TTL_SECONDS=180
VISTA_ANALYSIS_CACHE_BACKEND=memory
VISTA_ANALYSIS_CACHE_PREFIX=vista:analysis
VISTA_ANALYSIS_FAIL_ON_PARTIAL=false
VISTA_REDIS_URL=

## Optional token/JWKS timeout and token-exchange cache controls
VISTA_TOKEN_HTTP_TIMEOUT_SECONDS=20
VISTA_AUTH_JWKS_TIMEOUT_SECONDS=15
VISTA_TOKEN_EXCHANGE_CACHE_TTL_SECONDS=300
VISTA_TOKEN_EXCHANGE_REFRESH_SKEW_SECONDS=30

## Optional transient retry controls
VISTA_TRANSIENT_RETRY_ATTEMPTS=3
VISTA_TRANSIENT_RETRY_BASE_SECONDS=0.75
VISTA_TRANSIENT_RETRY_MAX_SECONDS=8
VISTA_TRANSIENT_RETRY_JITTER_SECONDS=0.25
VISTA_TRANSIENT_RETRY_STATUS_CODES=429,500,502,503,504

## Optional canary and rollback guardrail controls
VISTA_RELIABILITY_CANARY_ENABLED=false
VISTA_RELIABILITY_CANARY_SAMPLE_RATE=0.1
VISTA_RELIABILITY_ROLLBACK_ERROR_RATE_THRESHOLD=0.05
VISTA_RELIABILITY_ROLLBACK_P95_MS_THRESHOLD=4000

## MCP transport mode: stdio (default) or streamable-http
VISTA_MCP_TRANSPORT=stdio
VISTA_MCP_HOST=127.0.0.1
VISTA_MCP_PORT=8000
VISTA_MCP_STREAMABLE_HTTP_PATH=/mcp
VISTA_MCP_JSON_RESPONSE=false
VISTA_MCP_STATELESS_HTTP=false
